# Copy this file to `.env` and fill in the credentials for the backend(s) you
# want to use. SpinRAG reads the relevant variables at construction time.

# --- OpenRouter (default backend) -------------------------------------------
# Required when backend="openrouter" (the default).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the OpenRouter base URL (default:
# https://openrouter.ai/api/v1). Set this when running behind a self-hosted
# OpenRouter-compatible gateway.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: attribution headers. OpenRouter uses them for rate-limit and
# analytics attribution.
# OPENROUTER_APP_NAME=SpinRAG
# OPENROUTER_SITE_URL=https://example.com


# --- llama.cpp server (backend="llamacpp") -----------------------------------
# SpinRAG talks to the server's built-in OpenAI-compatible API. Start the
# server with the embedding flag enabled if you want to use the embeddings
# endpoint as well:
#
#   ./llama-server -m model.gguf --port 8080 --embedding
#
# The default base URL points at a locally-running server on port 8080.
# LLAMACPP_BASE_URL=http://localhost:8080/v1

# The llama.cpp server does not authenticate requests by default; the OpenAI
# SDK still requires a non-empty value, so any string works.
# LLAMACPP_API_KEY=sk-no-key-required
